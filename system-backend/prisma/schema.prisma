generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   // superadmin, deptadmin, driver, coordinator, student, parent
  phone     String?
  status    String   @default("active") // active, inactive, suspended
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Driver relation
  assignedVehicle Vehicle? @relation("DriverVehicle")
  license      String?
  // Student relation
  department   String?
  year         String?
  paymentStatus String?
  // Parent / Student relation (simple one to many for demo)
  parentId     String?
}

model Vehicle {
  id                 String   @id @default(uuid())
  number             String   @unique
  type               String   // bus, car
  vehicleTypeId      String?  // classification ID e.g. "BUS-60", "CAR-08"
  model              String?
  capacity           Int?
  status             String   @default("active") // active, maintenance, inactive
  route              String?
  circleNumber       String?
  rcDetails          String?
  chassisNumber      String?
  purchaseDate       String?
  maintenanceDueDate String?
  kmRun              Int?     @default(0)
  haltedCount        Int?     @default(0)
  image              String?

  // Relations
  driver               User?    @relation("DriverVehicle", fields: [driverId], references: [id])
  driverId             String?  @unique
  assignedStudents     VehicleStudentAssignment[]
  assignedCoordinators VehicleCoordinatorAssignment[]
}

// ── Vehicle ↔ Student assignment (permanent home bus) ──────────────────────────
model VehicleStudentAssignment {
  id          String   @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  studentId   String
  studentName String   @default("")
  class       String?  // department / year
  pickupPoint String?
  assignedAt  DateTime @default(now())
  assignedBy  String   @default("admin")
  @@unique([vehicleId, studentId])
}

// ── Vehicle ↔ Coordinator assignment ──────────────────────────────────────────
model VehicleCoordinatorAssignment {
  id              String   @id @default(uuid())
  vehicleId       String
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  coordinatorId   String
  coordinatorName String   @default("")
  assignedAt      DateTime @default(now())
  assignedBy      String   @default("admin")
  @@unique([vehicleId, coordinatorId])
}

// ── Immutable audit log for member assignment changes ──────────────────────────
model VehicleAssignmentAuditLog {
  id        String   @id @default(uuid())
  vehicleId String
  action    String   // assigned_members | removed_student | removed_coordinator | updated_driver
  details   String   @default("{}") // JSON string snapshot
  adminId   String   @default("admin")
  adminName String   @default("Super Admin")
  createdAt DateTime @default(now())
}


model Attendance {
  id          String   @id @default(uuid())
  userId      String
  vehicleId   String
  type        String   // driver_scan, student_scan
  latitude    Float?
  longitude   Float?
  scannedAt   DateTime @default(now())
}

model Issue {
  id          String   @id @default(uuid())
  type        String
  description String
  vehicleId   String?
  reportedBy  String
  status      String   @default("open") // open, resolved
  createdAt   DateTime @default(now())
}

model ServiceRequest {
  id          String    @id @default(uuid())
  requestType String                         // Oil Change, Brake Inspection, etc.
  description String
  vehicleId   String?
  driverName  String
  driverId    String?
  priority    String    @default("medium")   // low, medium, high, critical
  status      String    @default("pending")  // pending, approved, rejected, in_progress, completed
  notes       String?                        // Admin notes on approval/rejection
  approvedBy  String?
  approvedAt  DateTime?
  completedAt DateTime?
  submittedAt DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ── Maintenance Alerts (raised from web admin, pushed to maintenance app) ──
model MaintenanceAlert {
  id           String   @id @default(uuid())
  vehicle      String                        // e.g. BUS-01
  issueType    String                        // Engine/Mechanical, Brakes, etc.
  description  String
  priority     String   @default("Medium")   // Critical, High, Medium, Low
  status       String   @default("Pending")  // Pending, Acknowledged, Resolved
  raisedBy     String   @default("Admin")
  acknowledgedBy String?
  resolvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── Bus Shutdown Events (pushed to student/parent/HoD/coordinator apps) ──
model BusShutdown {
  id              String   @id @default(uuid())
  vehicle         String                      // Bus that is offline e.g. BUS-01
  reason          String                      // Short description
  replacementBus  String?                     // e.g. BUS-05
  affectedRoute   String?                     // e.g. Route 7 (Theni)
  priority        String   @default("High")
  status          String   @default("Active") // Active, Resolved
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Student ↔ Vehicle Mapping (supports original + active override) ──
model StudentVehicleMapping {
  id                String   @id @default(uuid())
  studentId         String   @unique
  studentName       String
  originalVehicleId String                    // Permanent home bus
  activeVehicleId   String                    // Current active bus (differs during temp swap)
  assignmentId      String?                   // FK to BusAssignment when temp swap is live
  pickupLocation    String?
  dropLocation      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ── Bus Reassignment Events (temporary or permanent) ──
model BusAssignment {
  id                    String   @id @default(uuid())
  fromVehicleId         String
  fromVehicleNumber     String
  toVehicleId           String
  toVehicleNumber       String
  assignmentType        String                // temporary | permanent
  status                String   @default("active") // active | expired | cancelled | converted_to_permanent
  startDate             DateTime
  endDate               DateTime?
  autoRestoreAt         DateTime?
  // Snapshot of all affected stakeholders (stored as JSON strings)
  studentsJson          String   @default("[]")  // [{id,name,phone}]
  parentsJson           String   @default("[]")  // [{id,name,phone,studentName}]
  studentCount          Int      @default(0)
  parentCount           Int      @default(0)
  // Rollback info
  previousDriverId      String?
  previousDriverName    String?
  newDriverId           String?
  newDriverName         String?
  previousRoute         String?
  newRoute              String?
  previousCoordinatorId String?
  newCoordinatorId      String?
  // Admin who executed the change
  adminId               String   @default("admin")
  adminName             String   @default("Super Admin")
  ipAddress             String?
  // Sync statuses
  notificationStatus    String   @default("pending")  // pending | sent | partial | failed
  notifiedCount         Int      @default(0)
  gpsSyncStatus         String   @default("synced")
  attendanceSyncStatus  String   @default("synced")
  transactionStatus     String   @default("success")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ── Immutable Audit Log for Bus Changes ──
model BusChangeAuditLog {
  id                   String   @id @default(uuid())
  assignmentId         String
  adminId              String
  adminName            String
  fromVehicle          String
  toVehicle            String
  previousDriver       String?
  newDriver            String?
  previousRoute        String?
  newRoute             String?
  assignmentType       String                // temporary | permanent
  effectiveDate        DateTime
  restorationDate      DateTime?
  studentsAffected     Int      @default(0)
  parentsNotified      Int      @default(0)
  notificationStatus   String   @default("sent")
  gpsSyncStatus        String   @default("synced")
  attendanceSyncStatus String   @default("synced")
  transactionStatus    String   @default("success")
  ipAddress            String?
  deviceInfo           String?
  notes                String?
  createdAt            DateTime @default(now())
}

// ── Route ↔ Vehicle Assignment ─────────────────────────────────────────────
model RouteVehicleAssignment {
  id            String   @id @default(uuid())
  routeId       String                        // logical route ID (e.g. RT-01)
  routeName     String                        // human label
  vehicleId     String
  vehicleNumber String
  isActive      Boolean  @default(true)
  assignedAt    DateTime @default(now())
  assignedBy    String   @default("admin")
  removedAt     DateTime?
  removedBy     String?
  notes         String?
  @@unique([routeId, vehicleId])
}

// ── Route Notification Log ─────────────────────────────────────────────────
model RouteNotification {
  id                  String   @id @default(uuid())
  routeId             String
  routeName           String
  vehicleIdsJson      String   @default("[]")  // JSON array of vehicleIds selected
  vehicleNumbersJson  String   @default("[]")  // JSON array of vehicle numbers
  notificationType    String   // RouteChange|EarlyArrival|DelayedDeparture|Diversion|Closure|Emergency|PickupChange|DropChange
  effectiveDate       String
  effectiveTime       String
  duration            String?                  // null = permanent
  updatedRoute        String?
  pickupChange        String?
  dropChange          String?
  customMessage       String?
  // Auto-retrieved stakeholder snapshot
  totalStudents       Int      @default(0)
  totalParents        Int      @default(0)
  totalDrivers        Int      @default(0)
  totalCoordinators   Int      @default(0)
  totalHods           Int      @default(0)
  stakeholdersJson    String   @default("{}")  // Full snapshot
  // Delivery
  status              String   @default("sent") // sent | queued | failed
  notifiedCount       Int      @default(0)
  // Audit
  adminId             String   @default("admin")
  adminName           String   @default("Super Admin")
  ipAddress           String?
  gpsSyncStatus       String   @default("synced")
  attendanceSyncStatus String  @default("synced")
  createdAt           DateTime @default(now())
}
